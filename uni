#include <stdio.h>

union details
{
    char name[50];
    char housename[50];
    char city[50];
    char state[50];
    char pincode[20];
};

int main()
{
    union details u;

    printf("Enter Name: ");
    scanf("%s", u.name);
    printf("Name: %s\n\n", u.name);

    printf("Enter House Name: ");
    scanf("%s", u.housename);
    printf("House Name: %s\n\n", u.housename);

    printf("Enter City: ");
    scanf("%s", u.city);
    printf("City: %s\n\n", u.city);

    printf("Enter State: ");
    scanf("%s", u.state);
    printf("State: %s\n\n", u.state);

    printf("Enter Pincode: ");
    scanf("%s", u.pincode);
    printf("Pincode: %s\n\n", u.pincode);

    return 0;
}
